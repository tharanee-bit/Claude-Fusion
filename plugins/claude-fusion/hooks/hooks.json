{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/claude-fusion-userprompt.sh",
            "timeout": 660,
            "statusMessage": "Claude Fusion is analyzing the task read-only"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/claude-fusion-subagent-stop.sh",
            "timeout": 660,
            "statusMessage": "Claude Fusion is reviewing the subagent result read-only"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/claude-fusion-stop.sh",
            "timeout": 660,
            "statusMessage": "Claude Fusion is reviewing the final diff read-only"
          }
        ]
      }
    ]
  }
}
